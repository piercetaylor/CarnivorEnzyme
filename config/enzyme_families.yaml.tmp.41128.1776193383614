  # ============================================================
  # 4. NEPENTHESINS / DROSERASINS (Aspartic proteases, A1B)
  # ============================================================
  # Primary digestive proteases of carnivorous plants
  # Merops family: A01.073 (nepenthesin subgroup)
  # Subfamilies:
  #   Nepenthesins I/II (Nepenthes spp.) — contain unique nepenthesin insert domain
  #   Droserasins (Drosera spp.) — related to pepsin
  #   Dionain (Dionaea muscipula) — aspartic protease
  # No experimental structure for nepenthesins (Kadek 2016 crystallized but coords not deposited)
  # Key literature:
  #   - Athauda et al. 2004, Biochem J — nepenthesin I and II characterization
  #   - Butts et al. 2016, Proteins — droserasin structure prediction
  #   - Takahashi et al. 2011, FEBS Lett — nepenthesin substrate specificity

  nepenthesins:
    merops: A01.073
    subfamily: A1B
    experimental_pdb: null          # Kadek 2016 crystallized at 2.8Å but coords NOT deposited
    convergent_source: "Fukushima et al. 2017"
    expected_length_aa: [380, 470]
    accessions:

      # --- Nepenthes (canonical nepenthesins) ---
      Nepenthes_gracilis:
        - AB114914      # VERIFIED: Nepenthesin I (Nep I), 437 aa; Athauda et al. 2004 ANCHOR
        - AB114915      # VERIFIED: Nepenthesin II (Nep II), 437 aa; Athauda et al. 2004 ANCHOR
        - GMG99884.1    # GENOME: Nepgr_001724, neprosin-related/AP, 467 aa (Saul 2023)

      Nepenthes_alata:
        - BBF98357.1    # VERIFIED: Nepenthesin III, 442 aa; Kadek et al. 2016
        - BAV14385.1    # VERIFIED: Nepenthesin II, 437 aa

      Nepenthes_mirabilis:
        - AFV26024.1    # VERIFIED: Nepenthesin 1, 437 aa; Takahashi et al. 2011
        - AFV26025.1    # VERIFIED: Nepenthesin 2, 437 aa; Takahashi et al. 2011

      # --- Drosera (droserasins) ---
      Drosera_capensis:
