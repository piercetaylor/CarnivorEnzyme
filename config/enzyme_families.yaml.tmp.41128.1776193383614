                        # NOTE: guard-cell AP may not be the digestive droserasin;
                        # TODO: cross-reference with Butts 2016 supplementary to get droserasin-1/2

      Drosera_rotundifolia:
        - TODO          # Search GAB (D. rotundifolia genome) for aspartic protease A1B

      # --- Dionaea (dionain) ---
      Dionaea_muscipula:
        - A0A0E3GLN3    # VERIFIED UniProt: Dionain-1, aspartic protease; Palfalvi 2020
        - A0A0E3M338    # VERIFIED UniProt: Dionain-3, aspartic protease; Palfalvi 2020

      # --- Outgroups (plant aspartic proteases, A1 family) ---
      Arabidopsis_thaliana:
        - NP_187876.2   # OUTGROUP VERIFIED: Eukaryotic aspartyl protease family, 461 aa
        - NP_565911.1   # OUTGROUP VERIFIED: Eukaryotic aspartyl protease family, 442 aa

      Solanum_lycopersicum:
        - XP_004253208.1 # OUTGROUP VERIFIED: ASPARTIC PROTEASE IN GUARD CELL 2, 486 aa
        - XP_019070220.2 # OUTGROUP VERIFIED: ASPARTIC PROTEASE IN GUARD CELL 1-like, 455 aa

      Hordeum_vulgare:
        - M0W9B2        # OUTGROUP VERIFIED: HvNEP-1 barley nepenthesin-like A1B, 427 aa
                        # Best-characterized non-carnivorous nepenthesin-subfamily member
                        # Published: Frontiers in Plant Science 2021; has canonical PSI insert
                        # Key use: outgroup for A1B subfamily nepenthesin phylogeny + FoldX ref
        - XP_045019345.1 # OUTGROUP: Hordeum nucellin-like (no PSI insert), 402 aa
                        # Contrast: nucellin lacks the PSI domain present in nepenthesins
