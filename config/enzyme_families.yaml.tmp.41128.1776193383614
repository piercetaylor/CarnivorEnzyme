      Triticum_aestivum:
        - XP_037427783.1 # OUTGROUP: wheat nepenthesin-like aspartic protease, 437 aa
                        # Close homolog to HvNEP-1; adds Triticeae lineage to outgroup
                        # TODO: verify length and A1B subfamily membership via MEROPS BLAST

      Vitis_vinifera:
