                        # TODO: verify A1 subfamily and length (search XP_ Vitis A1 family)


  # ============================================================
  # 5. NEPROSINS (Glutamic peptidases, G3 / DUF239)
  # ============================================================
  # Unique to Nepenthes — not found in other carnivorous lineages
  # Merops family: G03.001 (neprosin-1)
  # Experimental structures available: 7ZVA, 7ZVB, 7ZVC, 7ZU8
  # Substrate: proline-containing peptides (cleaves after Pro)
  # Biotech application: gluten/gliadin digestion (coeliac disease therapy)
  # Key literature:
  #   - Del Amo-Maestro et al. 2022, Nat. Commun. — crystal structures (PDB 7ZVA-C, 7ZU8)
  #   - Schräder et al. 2017, Mol Cell Proteomics — neprosin as prolyl endoprotease
  #   - Tiew & Goh 2022 — placed in glutamic peptidase family G3
  #   - Ting et al. 2026 — gluten detoxification with neprosin

  neprosins:
    merops: G03.001
    subfamily: G3
    experimental_pdb:
      - "7ZVA"    # Zymogen native, 1.80 Å — primary validation target
      - "7ZVB"    # Mature form, 2.35 Å
      - "7ZVC"    # Mature form (crystal form 2), 1.85 Å
      - "7ZU8"    # Zymogen + inhibitor Lu-Xo4, 2.05 Å
    convergent_source: "Not applicable — Nepenthes-specific family"
    expected_length_aa: [370, 470]
    notes: "Nepenthes-specific; no other carnivorous lineage has this family. Convergence analysis not applicable but structural comparison across Nepenthes species IS planned."
    accessions:

      # --- Nepenthes gracilis (primary species) ---
      Nepenthes_gracilis:
        - GMG99884.1    # GENOME: Nepgr_001724, 467 aa (Saul 2023) — may be neprosin
        - GMH01265.1    # GENOME: Nepgr_003104, 445 aa (Saul 2023) — may be neprosin
                        # NOTE: Saul 2023 genome predicts ~8 neprosin paralogs; confirm annotation

      # --- Nepenthes ampullaria (high-pH pitcher, pH~5 — useful for pH comparison) ---
      Nepenthes_ampullaria:
        - ARA95696.1    # VERIFIED: Neprosin 2, 421 aa
        - ARA95695.1    # VERIFIED: Neprosin 1, 421 aa

      # --- Nepenthes ventrata (source of crystal structures) ---
      Nepenthes_ventrata:
        - C0HLV2.1      # VERIFIED UniProt: Neprosin (Npr1), 380 aa — mature form
                        # This is the sequence used for crystal structures 7ZVA-C

      # --- Additional Nepenthes species (for cross-species comparison) ---
      Nepenthes_rafflesiana:
        - TODO          # Low-pH pitcher (~pH 2); important for pH-stability comparison

      Nepenthes_bicalcarata:
        - TODO          # Mutualistic species (ants in pitchers); reduced acid secretion

      # NOTE: No neprosin homologs found outside Nepenthes as of April 2026
      # No outgroup sequences needed for this family (no convergence analysis)


