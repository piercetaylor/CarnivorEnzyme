# Enzyme families and protein accessions for CarnivorEnzyme pipeline.
# Used by: fetch_sequences.py, retrieve.smk
#
# Accession format: NCBI protein accession (e.g. BAF98919.1) or UniProt ID (e.g. C0HLV2)
# All accessions verified against NCBI Protein database, April 2026.
#
# Annotation conventions:
#   # VERIFIED: accession confirmed in NCBI/UniProt with correct annotation
#   # GENOME:   derived from genome annotation (may be hypothetical protein)
#   # TODO:     accession not yet found; requires supplementary table from cited paper
#   # PARTIAL:  sequence is incomplete (<80% expected length); flag for length filter
#   # OUTGROUP: non-carnivorous outgroup sequence
#
# Length ranges (expected full-length for filtering):
#   GH19 chitinases:         250-350 aa (mature); flag <200 aa
#   Purple acid phosphatase: 420-680 aa; flag <350 aa (some are truncated isoforms)
#   RNase T2:                200-270 aa; flag <180 aa
#   Nepenthesins (A1B):      380-460 aa (preproenzyme); flag <300 aa
#   Neprosins (G3):          370-470 aa (zymogen); flag <300 aa

tier1:

  # ============================================================
  # 1. GH19 CHITINASES (Class IV acidic chitinases)
  # ============================================================
  # Convergent substitutions: Fukushima et al. 2017, Nature Ecol. Evol., Fig. 3a
  # CAZy family: GH19 (glycoside hydrolase family 19)
  # Expected size: ~270-340 aa mature form
  # Key literature:
  #   - Fukushima et al. 2017 — convergent substitutions identified
  #   - Yoneda et al. 2025, FEBS Open Bio — D. adelae chitinase structurally characterized
  #   - Yoneda et al. 2025: first carnivorous plant chitinase with experimental structure (PDB?)
  #   - Drosera binata DbChitI-3 chitinase: pH optimum 2.5, induced by prey (Planta 2025)
  #   - GH19 Engineering Database (PMC8547705) — comprehensive sequence/diversity resource
  #   - Rye (Secale cereale) chitinase PDB 4J0L: crystal structure reference for GH19 fold
  #   - Nepenthes chitinase NkChit2b-1 (Springer 2025) — insect resistance

  chitinases_gh19:
    cazy: GH19
    merops: null
    convergent_source: "Fukushima et al. 2017 Fig. 3a"
    expected_length_aa: [250, 350]
    accessions:

      # --- Nepenthes (Caryophyllales, pitfall pitcher) ---
      Nepenthes_gracilis:
